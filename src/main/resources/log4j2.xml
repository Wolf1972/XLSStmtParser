<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="INFO" monitorInterval="30">
    <Properties>
        <!-- <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</Property> -->
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level: %msg%n</Property>
        <Property name="LOG_DIR">logs</Property>
    </Properties>

    <Appenders>
        <!-- Console appender -->
        <Console name="Console" target="SYSTEM_OUT">
            <!-- <PatternLayout pattern="%d{HH:mm:ss.SSS} %highlight{%-5level} [%thread] %logger{36} - %msg%n"/> -->
            <PatternLayout pattern="%d{HH:mm:ss} %highlight{%-5level}: %msg%n"/>
        </Console>

        <!-- File appender -->
        <RollingFile name="FileLogger"
                     fileName="${LOG_DIR}/application.log"
                     filePattern="${LOG_DIR}/application-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <!-- New file for every day -->
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <!-- Or when 100M approached -->
                <SizeBasedTriggeringPolicy size="100MB"/>
            </Policies>
            <!-- Store 30 days max or 10G max -->
            <DefaultRolloverStrategy max="30">
                <Delete basePath="${LOG_DIR}" maxDepth="1">
                    <IfFileName glob="application-*.log.gz" />
                    <IfLastModified age="30d" />
                    <IfAccumulatedFileSize exceeds="10GB" />
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>

        <!-- Additional file for errors only -->
        <RollingFile name="ErrorFileLogger"
                     fileName="${LOG_DIR}/errors.log"
                     filePattern="${LOG_DIR}/errors-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <!-- <LevelRangeFilter minLevel="WARN" maxLevel="FATAL" onMatch="ACCEPT" onMismatch="DENY"/> -->
            <LevelRangeFilter minLevel="WARN" maxLevel="FATAL" />
            <Policies>
                <SizeBasedTriggeringPolicy size="50MB"/>
            </Policies>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="FileLogger"/>
            <AppenderRef ref="ErrorFileLogger"/>
        </Root>

        <!-- Can define different levels for different packets -->
        <Logger name="ru.bis.javautil" level="DEBUG"/>
    </Loggers>
</Configuration>